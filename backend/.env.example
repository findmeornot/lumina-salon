NODE_ENV=development
HOST=127.0.0.1
PORT=5000
FRONTEND_URL=http://localhost:5173,http://localhost:5174
JWT_SECRET=replace_with_secure_secret
JWT_EXPIRES_IN=7d
APP_PUBLIC_URL=http://localhost:5173
PASSWORD_RESET_TTL_MINUTES=30
DB_HOST=localhost
DB_PORT=3306
DB_USER=root
DB_PASSWORD=
DB_NAME=lumina
DB_POOL_LIMIT=25

# Railway MySQL plugin variables are also supported:
# MYSQLHOST, MYSQLPORT, MYSQLUSER, MYSQLPASSWORD, MYSQLDATABASE
# Or a single connection string:
# DATABASE_URL / MYSQL_URL / MYSQL_PUBLIC_URL (mysql://user:pass@host:port/db)

# Enable DB connection diagnostics at boot (prints current DB + table list)
DEBUG_DB=false
DEBUG_CORS=false
UPLOAD_DIR=uploads
ROOM_QR_SECRET=LUMINA_ROOM_FIXED_QR
ROOM_CODE_TTL_MINUTES=10
WHATSAPP_PROVIDER_URL=
WHATSAPP_PROVIDER_TOKEN=
WHATSAPP_SENDER=Lumina

# SMTP (for password reset emails)
SMTP_HOST=
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=
SMTP_FROM=Lumina <no-reply@lumina.local>

# Optional: Admin dashboard login via username/password (no email).
# WARNING: Enable only in trusted environments.
ADMIN_DASH_LOGIN_ENABLED=false
ADMIN_DASH_USERNAME=lumina@admin
ADMIN_DASH_PASSWORD=lumina@12345
ADMIN_DASH_EMAIL=admin@lumina.local
